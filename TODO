Google distance calculation

code example:

const kmBasiMaliyet = 2;

async function mesafeHesapla(depoAdresi, varisAdresi, apiAnahtari) {
    const url = "https://maps.googleapis.com/maps/api/distancematrix/json";

    const params = new URLSearchParams({
        'origins': depoAdresi,
        'destinations': varisAdresi,
        'key': apiAnahtari
    });

    try {
        const response = await fetch(`${url}?${params}`);
        const data = await response.json();

        if (data.status === 'OK') {
            try {
                const mesafeText = data.rows[0].elements[0].distance.text;
                const mesafeKm = parseFloat(mesafeText.replace(' km', '').replace(',', '.'));
                return mesafeKm;
            } catch (e) {
                console.log("Mesafe bilgisi alınırken bir hata oluştu:", e);
                return null;
            }
        } else {
            console.log("Mesafe hesaplanamadı. Hata:", data.status);
            return null;
        }
    } catch (error) {
        console.log("API isteği sırasında bir hata oluştu:", error);
        return null;
    }
}

const depoAdresi = "Rue de Ribaucourt 154, 1080 Bruxelles";
const varisAdresi = "Rue maieur haniquelle 87080 La Bouverie (Frameries)";
const apiAnahtari = "AIzaSyBd14HXNErDsKbLgWyIP0mGXRvaXXlOcfg";  // Buraya kendi Google Maps API anahtarınızı girin

mesafeHesapla(depoAdresi, varisAdresi, apiAnahtari).then(mesafeKm => {
    if (mesafeKm !== null) {
        const toplamMaliyet = mesafeKm * kmBasiMaliyet;
    }
});
